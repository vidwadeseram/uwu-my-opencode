+import { describe, expect, test } from "bun:test"
+import path from "path"
+import { tmpdir } from "../fixture/fixture"
+import { ReportManifest } from "../../src/report/manifest"
+
+describe("ReportManifest", () => {
+  test("writes and reads manifest with defaults", async () => {
+    await using tmp = await tmpdir()
+    const file = path.join(tmp.path, "logs", "run", "manifest.json")
+
+    await ReportManifest.write(file, {
+      run_id: "2026-03-2311-10-00",
+      created_at: "2026-03-23T11:10:00.000Z",
+      artifacts: {
+        html: "./index.html",
+        screenshots: "screenshots/",
+        video: "video",
+      },
+    })
+
+    const data = await ReportManifest.read(file)
+
+    expect(data.run_id).toBe("2026-03-2311-10-00")
+    expect(data.suite).toBe("regression")
+    expect(data.status).toBe("partial")
+    expect(data.summary.total).toBe(0)
+    expect(data.artifacts.html).toBe("index.html")
+    expect(data.artifacts.screenshots).toBe("screenshots")
+    expect(data.artifacts.video).toBe("video")
+  })
+
+  test("rejects malformed manifest and unsafe paths", async () => {
+    await using tmp = await tmpdir()
+    const file = path.join(tmp.path, "logs", "run", "manifest.json")
+
+    await expect(
+      ReportManifest.write(file, {
+        run_id: "",
+        created_at: "2026-03-23T11:10:00.000Z",
+      }),
+    ).rejects.toThrow("invalid manifest: missing run_id")
+
+    await expect(
+      ReportManifest.write(file, {
+        run_id: "2026-03-2311-10-00",
+        created_at: "2026-03-23T11:10:00.000Z",
+        artifacts: { html: "../../etc/passwd" },
+      }),
+    ).rejects.toThrow("invalid artifact path")
+  })
+})
