+import { Hono } from "hono"
+import { describeRoute, resolver, validator } from "hono-openapi"
+import z from "zod"
+import path from "path"
+import { lazy } from "@/util/lazy"
+import { Instance } from "@/project/instance"
+import { ReportList } from "@/report/list"
+import { ReportRun } from "@/report/run"
+import { ReportHTML } from "@/report/html"
+import { ReportTemplate } from "@/report/template"
+import { Filesystem } from "@/util/filesystem"
+
+function day(v: string | null) {
+  if (!v) return "unknown"
+  const hit = v.match(/^(\d{4}-\d{2}-\d{2})/)
+  if (!hit) return "unknown"
+  return hit[1]
+}
+
+function group(rows: Awaited<ReturnType<typeof ReportList.list>>) {
+  const map = new Map<string, typeof rows>()
+  for (const row of rows) {
+    const k = day(row.createdAt)
+    const list = map.get(k) ?? []
+    list.push(row)
+    map.set(k, list)
+  }
+  return [...map.entries()]
+}
+
+function row(x: (Awaited<ReturnType<typeof ReportList.list>>)[number]) {
+  const issue = x.issue ? `<p class="warn">${ReportTemplate.esc(x.issue)}</p>` : ""
+  const sum = `${x.summary.passed}/${x.summary.total} passed • ${x.summary.failed} failed • ${x.summary.skipped} skipped`
+  const made = x.createdAt ? ReportTemplate.esc(x.createdAt) : "unknown"
+  return [
+    '<li class="card">',
+    '<div class="line">',
+    `<a href="${ReportTemplate.esc(x.route)}" data-run-id="${ReportTemplate.esc(x.id)}"><code>${ReportTemplate.esc(x.id)}</code></a>`,
+    `<span class="badge status-${ReportTemplate.esc(x.status)}">${ReportTemplate.esc(x.status)}</span>`,
+    "</div>",
+    `<p class="muted">Created: <code>${made}</code></p>`,
+    `<p class="muted">Summary: ${ReportTemplate.esc(sum)}</p>`,
+    issue,
+    "</li>",
+  ].join("\n")
+}
+
+function index(rows: Awaited<ReturnType<typeof ReportList.list>>) {
+  const latest = rows[0] ? `<a class="btn latest" href="${ReportTemplate.esc(rows[0].route)}">Open latest run</a>` : ""
+  if (rows.length === 0) {
+    return ReportTemplate.doc({
+      title: "Regression Reports",
+      body: [
+        '<header><div><h1>Regression Reports</h1><p>Browse generated HTML runs and artifacts.</p></div></header>',
+        '<section class="card"><p data-empty="true">No report runs available yet.</p></section>',
+      ].join("\n"),
+    })
+  }
+
+  const blocks = group(rows)
+    .map(([k, list], i) => {
+      return [
+        `<details class="card" ${i === 0 ? "open" : ""}>`,
+        `<summary class="line"><span><strong>${ReportTemplate.esc(k)}</strong></span><span class="muted">${list.length} runs</span></summary>`,
+        '<ul class="clean stack" style="margin-top:10px">',
+        list.map((x) => row(x)).join("\n"),
+        "</ul>",
+        "</details>",
+      ].join("\n")
+    })
+    .join("\n")
+
+  return ReportTemplate.doc({
+    title: "Regression Reports",
+    body: [
+      '<header><div><h1>Regression Reports</h1><p>Run groups are collapsible by date. Open any run to view screenshots and video.</p></div>',
+      latest,
+      "</header>",
+      '<section class="stack">',
+      blocks,
+      "</section>",
+    ].join("\n"),
+  })
+}
+
+function root() {
+  return path.join(Instance.directory, "logs")
+}
+
+function run(root: string, id: string) {
+  return path.join(root, ReportRun.validate(id))
+}
+
+function safe(base: string, rel: string) {
+  const clean = rel.replaceAll("\\", "/")
+  if (clean.includes("..")) return
+  if (clean.startsWith("/")) return
+  const full = path.join(base, clean)
+  if (!Filesystem.contains(base, full)) return
+  return full
+}
+
+export const ReportRoutes = lazy(() =>
+  new Hono()
+    .get(
+      "/",
+      describeRoute({
+        summary: "List report runs",
+        description: "List available regression report runs from logs directory.",
+        operationId: "report.list",
+        responses: {
+          200: {
+            description: "Report runs",
+            content: {
+              "application/json": {
+                schema: resolver(
+                  z
+                    .object({
+                      id: z.string(),
+                      route: z.string(),
+                      createdAt: z.string().nullable(),
+                      status: z.enum(["running", "pass", "fail", "partial"]),
+                      summary: z.object({
+                        total: z.number(),
+                        passed: z.number(),
+                        failed: z.number(),
+                        skipped: z.number(),
+                      }),
+                      issue: z.string().nullable(),
+                    })
+                    .array(),
+                ),
+              },
+            },
+          },
+        },
+      }),
+      async (c) => {
+        const dir = root()
+        const data = await ReportList.list(dir)
+        const accept = c.req.header("accept") ?? ""
+        const format = c.req.query("format")
+        if (format === "json" || accept.includes("application/json")) {
+          return c.json(data)
+        }
+        c.header("content-type", "text/html; charset=utf-8")
+        return c.body(index(data))
+      },
+    )
+    .get(
+      "/:runId",
+      describeRoute({
+        summary: "Get report HTML",
+        description: "Serve report index page for a run id.",
+        operationId: "report.get",
+        responses: {
+          200: {
+            description: "Report HTML",
+            content: {
+              "text/html": {
+                schema: resolver(z.string()),
+              },
+            },
+          },
+          404: {
+            description: "Run not found",
+          },
+        },
+      }),
+      validator(
+        "param",
+        z.object({
+          runId: z.string(),
+        }),
+      ),
+      async (c) => {
+        const dir = root()
+        const id = c.req.valid("param").runId
+        const runDir = run(dir, id)
+        if (!(await Filesystem.isDir(runDir))) return c.json({ error: "run not found" }, 404)
+        const out = await ReportHTML.generate({ root: dir, id })
+        const html = await Filesystem.readText(out.index)
+        c.header("content-type", "text/html; charset=utf-8")
+        return c.body(html)
+      },
+    )
+    .get(
+      "/:runId/*",
+      validator(
+        "param",
+        z.object({
+          runId: z.string(),
+        }),
+      ),
+      async (c) => {
+        const dir = root()
+        const id = c.req.valid("param").runId
+        const runDir = run(dir, id)
+        if (!(await Filesystem.isDir(runDir))) return c.json({ error: "run not found" }, 404)
+        const prefix = `/reports/${id}/`
+        const raw = c.req.path.startsWith(prefix) ? c.req.path.slice(prefix.length) : ""
+        const rel = (() => {
+          try {
+            return decodeURIComponent(raw)
+          } catch {
+            return raw
+          }
+        })()
+        const target = safe(runDir, rel)
+        if (!target) return c.json({ error: "invalid report path" }, 400)
+        if (!(await Filesystem.exists(target))) return c.json({ error: "file not found" }, 404)
+        const bytes = await Filesystem.readBytes(target)
+        return new Response(new Uint8Array(bytes), {
+          headers: {
+            "content-type": Filesystem.mimeType(target),
+          },
+        })
+      },
+    ),
+)
