@@ -0,0 +1,135 @@
+import path from "path"
+import type { Argv } from "yargs"
+import { bootstrap } from "@/cli/bootstrap"
+import { cmd } from "@/cli/cmd/cmd"
+import { ReportRun } from "@/report/run"
+import { ReportList } from "@/report/list"
+import { ReportHTML } from "@/report/html"
+import { UI } from "@/cli/ui"
+
+function root(input?: string) {
+  return path.resolve(input ?? path.join(process.cwd(), "logs"))
+}
+
+function route(id: string) {
+  return `/reports/${id}`
+}
+
+function link(base: string, p: string) {
+  return new URL(p, base.endsWith("/") ? base : `${base}/`).toString()
+}
+
+export const ReportCommand = cmd({
+  command: "report",
+  describe: "manage regression report runs",
+  builder: (yargs: Argv) => yargs.command(ReportGenerateCommand).command(ReportOpenLatestCommand).demandCommand(),
+  async handler() {},
+})
+
+export const ReportGenerateCommand = cmd({
+  command: "generate",
+  describe: "create a regression report run folder",
+  builder: (yargs: Argv) =>
+    yargs
+      .option("logs-root", {
+        type: "string",
+        describe: "root directory for report runs",
+        default: "logs",
+      })
+      .option("run-id", {
+        type: "string",
+        describe: "optional run id override",
+      })
+      .option("base-url", {
+        type: "string",
+        describe: "server base URL used for report links",
+        default: "http://127.0.0.1:4096",
+      })
+      .option("json", {
+        type: "boolean",
+        describe: "print machine-readable output",
+        default: false,
+      }),
+  handler: async (args) => {
+    await bootstrap(process.cwd(), async () => {
+      const out = await ReportRun.create({
+        root: root(args.logsRoot),
+        id: args.runId,
+      })
+      const html = await ReportHTML.generate({
+        root: root(args.logsRoot),
+        id: out.id,
+      })
+      const p = route(out.id)
+      const url = link(args.baseUrl, p)
+      if (args.json) {
+        console.log(
+          JSON.stringify(
+            {
+              runId: out.id,
+              dir: out.dir,
+              route: p,
+              url,
+              index: html.index,
+              warnings: html.warnings,
+            },
+            null,
+            2,
+          ),
+        )
+        return
+      }
+      UI.println(`runId: ${out.id}`)
+      UI.println(`dir: ${out.dir}`)
+      UI.println(`route: ${p}`)
+      UI.println(`url: ${url}`)
+      UI.println(`index: ${html.index}`)
+      if (html.warnings.length) UI.println(`warnings: ${html.warnings.join(", ")}`)
+    })
+  },
+})
+
+export const ReportOpenLatestCommand = cmd({
+  command: "open-latest",
+  describe: "resolve URL for latest report run",
+  builder: (yargs: Argv) =>
+    yargs
+      .option("logs-root", {
+        type: "string",
+        describe: "root directory for report runs",
+        default: "logs",
+      })
+      .option("base-url", {
+        type: "string",
+        describe: "server base URL used for report links",
