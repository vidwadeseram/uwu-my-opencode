diff --git a/packages/opencode/src/report/html.ts b/packages/opencode/src/report/html.ts
new file mode 100644
index 0000000..5851823
--- /dev/null
+++ b/packages/opencode/src/report/html.ts
@@ -0,0 +1,86 @@
+import fs from "fs/promises"
+import path from "path"
+import { Filesystem } from "@/util/filesystem"
+import { ReportManifest } from "@/report/manifest"
+import { ReportRun } from "@/report/run"
+import { ReportTemplate } from "@/report/template"
+
+async function walk(base: string, dir: string): Promise<string[]> {
+  const list = await fs.readdir(dir, { withFileTypes: true }).catch(() => [])
+  const out = await Promise.all(
+    list.map(async (x) => {
+      const full = path.join(dir, x.name)
+      if (x.isDirectory()) return walk(base, full)
+      return [path.relative(base, full).split(path.sep).join("/")]
+    }),
+  )
+  return out.flat()
+}
+
+function page(input: { id: string; created: string; shots: string[]; videos: string[]; warnings: string[] }) {
+  const shots =
+    input.shots.length === 0
+      ? '<p class="warn" data-warning="screenshots">No screenshots found.</p>'
+      : `<ul class="clean grid">${input.shots
+          .map(
+            (x) =>
+              `<li class="card"><figure><a href="${ReportTemplate.esc(x)}"><img loading="lazy" src="${ReportTemplate.esc(x)}" alt="${ReportTemplate.esc(x)}" /></a><figcaption><a href="${ReportTemplate.esc(x)}">${ReportTemplate.esc(x)}</a></figcaption></figure></li>`,
+          )
+          .join("")}</ul>`
+  const videos =
+    input.videos.length === 0
+      ? '<p class="warn" data-warning="video">No video found.</p>'
+      : `<ul class="clean grid">${input.videos
+          .map(
+            (x) =>
+              `<li class="card"><figure><video controls preload="metadata" src="${ReportTemplate.esc(x)}"></video><figcaption><a href="${ReportTemplate.esc(x)}">${ReportTemplate.esc(x)}</a></figcaption></figure></li>`,
+          )
+          .join("")}</ul>`
+  const warn =
+    input.warnings.length === 0
+      ? ""
+      : `<section class="card"><div class="line"><h2>Warnings</h2><span class="badge status-partial">attention</span></div><ul class="clean">${input.warnings
+          .map((x) => `<li class="warn">${ReportTemplate.esc(x)}</li>`)
+          .join("")}</ul></section>`
+
+  return ReportTemplate.doc({
+    title: `Regression Run ${input.id}`,
+    body: [
+      "<header>",
+      `<div><h1>Regression Run <code>${ReportTemplate.esc(input.id)}</code></h1><p>Created at <code>${ReportTemplate.esc(input.created)}</code></p></div>`,
+      '<a class="btn" href="/reports">Back to reports</a>',
+      "</header>",
+      '<div class="stack">',
+      warn,
+      '<section class="card"><h2>Screenshots</h2>',
+      shots,
+      "</section>",
+      '<section class="card"><h2>Video</h2>',
+      videos,
+      "</section>",
+      "</div>",
+    ].join("\n"),
+  })
+}
+
+export namespace ReportHTML {
+  export async function generate(input: { root: string; id: string }) {
+    const id = ReportRun.validate(input.id)
+    const root = path.resolve(input.root)
+    const dir = path.join(root, id)
+    const index = path.join(dir, "index.html")
+    const file = path.join(dir, "manifest.json")
+    const data = await ReportManifest.read(file).catch(() =>
+      ReportManifest.from({
+        run_id: id,
+        created_at: new Date().toISOString(),
+      }),
+    )
+    const all = await walk(dir, dir)
+    const shots = all.filter((x) => /\.(png|jpg|jpeg|webp)$/i.test(x))
+    const videos = all.filter((x) => /\.(mp4|webm)$/i.test(x))
+    const warnings = [shots.length === 0 ? "Missing screenshots" : "", videos.length === 0 ? "Missing video" : ""].filter(Boolean)
+    await Filesystem.write(index, page({ id, created: data.created_at, shots, videos, warnings }))
+    return { index, shots, videos, warnings }
+  }
+}
diff --git a/packages/opencode/src/report/list.ts b/packages/opencode/src/report/list.ts
new file mode 100644
index 0000000..07f5d37
--- /dev/null
+++ b/packages/opencode/src/report/list.ts
@@ -0,0 +1,117 @@
+import fs from "fs/promises"
+import path from "path"
+import { ReportManifest, type ReportStatus, type ReportSummary } from "@/report/manifest"
+import { ReportRun } from "@/report/run"
+
+export type ReportRow = {
+  id: string
+  route: string
+  createdAt: string | null
+  status: ReportStatus
+  summary: ReportSummary
+  issue: string | null
+}
+
+function stamp(id: string) {
+  const hit = id.match(/^(\d{4})-(\d{2})-(\d{2})(\d{2})-(\d{2})-(\d{2})$/)
+  if (!hit) return -1
+  const y = Number(hit[1])
+  const m = Number(hit[2])
+  const d = Number(hit[3])
+  const h = Number(hit[4])
+  const min = Number(hit[5])
+  const s = Number(hit[6])
+  if ([y, m, d, h, min, s].some((x) => Number.isNaN(x))) return -1
+  return Date.UTC(y, m - 1, d, h, min, s)
+}
+
+function issue(input: { manifest: string | null; shots: boolean; video: boolean; html: boolean }) {
+  const out = [
+    input.manifest,
+    input.shots ? null : "missing screenshots directory",
+    input.video ? null : "missing video directory",
+    input.html ? null : "missing report html",
+  ].filter((x) => !!x)
+  if (out.length === 0) return null
+  return out.join(", ")
+}
+
+async function row(root: string, id: string): Promise<ReportRow> {
+  const dir = path.join(root, id)
+  const file = path.join(dir, "manifest.json")
+  const parsed = await ReportManifest.read(file).catch((err) => {
+    const message = err instanceof Error ? err.message : String(err)
+    return { error: message } as const
+  })
+  const shots = await fs
+    .stat(path.join(dir, "screenshots"))
+    .then((x) => x.isDirectory())
+    .catch(() => false)
+  const video = await fs
+    .stat(path.join(dir, "video"))
+    .then((x) => x.isDirectory())
+    .catch(() => false)
+  const html = await fs
+    .stat(path.join(dir, "index.html"))
+    .then((x) => x.isFile())
+    .catch(() => false)
+
+  if ("error" in parsed) {
+    const note = issue({ manifest: parsed.error, shots, video, html })
+    return {
+      id,
+      route: `/reports/${id}`,
+      createdAt: null,
+      status: "partial",
+      summary: { total: 0, passed: 0, failed: 0, skipped: 0 },
+      issue: note,
+    }
+  }
+
+  const mismatch = parsed.run_id === id ? null : "manifest run_id mismatch"
+  const note = issue({ manifest: mismatch, shots, video, html })
+  return {
+    id,
+    route: `/reports/${id}`,
+    createdAt: parsed.created_at,
+    status: note ? "partial" : parsed.status,
+    summary: parsed.summary,
+    issue: note,
+  }
+}
+
+export namespace ReportList {
+  export async function ids(root: string) {
+    const rows = await list(root)
+    return rows.map((x) => x.id)
+  }
+
+  export async function list(root: string) {
+    const dir = path.resolve(root)
+    const dirs = await fs.readdir(dir, { withFileTypes: true }).catch(() => [])
+    const valid = dirs
+      .filter((x) => x.isDirectory())
+      .map((x) => x.name)
+      .filter((x) => {
+        try {
+          ReportRun.validate(x)
+          return true
+        } catch {
+          return false
+        }
+      })
+    const rows = await Promise.all(valid.map((id) => row(dir, id)))
+    return rows.sort((a, b) => {
+      const at = stamp(a.id)
+      const bt = stamp(b.id)
+      if (bt !== at) return bt - at
+      if (a.id === b.id) return 0
+      return a.id < b.id ? 1 : -1
+    })
+  }
+
+  export async function latest(root: string) {
+    const list = await ids(root)
+    return list[0]
+  }
+}
diff --git a/packages/opencode/src/report/manifest.ts b/packages/opencode/src/report/manifest.ts
new file mode 100644
index 0000000..e5450f9
--- /dev/null
+++ b/packages/opencode/src/report/manifest.ts
@@ -0,0 +1,105 @@
+import path from "path"
+import { Filesystem } from "@/util/filesystem"
+
+export type ReportStatus = "running" | "pass" | "fail" | "partial"
+
+export interface ReportSummary {
+  total: number
+  passed: number
+  failed: number
+  skipped: number
+}
+
+export interface ReportArtifacts {
+  html: string
+  screenshots: string
+  video: string
+}
+
+export interface ReportManifest {
+  run_id: string
+  created_at: string
+  suite: string
+  started_at?: string
+  ended_at?: string
+  status: ReportStatus
+  summary: ReportSummary
+  artifacts: ReportArtifacts
+}
+
+type ReportManifestInput = Omit<Partial<ReportManifest>, "artifacts" | "summary"> &
+  Pick<ReportManifest, "run_id" | "created_at"> & {
+    summary?: Partial<ReportSummary>
+    artifacts?: Partial<ReportArtifacts>
+  }
+
+function clean(v: string) {
+  return v.replaceAll("\\", "/")
+}
+
+function relative(v: string) {
+  const p = clean(v).trim()
+  if (!p) throw new Error("invalid artifact path: empty")
+  if (path.isAbsolute(p)) throw new Error(`invalid artifact path: ${v}`)
+  const n = path.posix.normalize(p)
+  if (n.startsWith("../") || n === "..") throw new Error(`invalid artifact path: ${v}`)
+  if (n.startsWith("/")) throw new Error(`invalid artifact path: ${v}`)
+  if (n.length > 1 && n.endsWith("/")) return n.slice(0, -1)
+  return n
+}
+
+function summary(v?: Partial<ReportSummary>): ReportSummary {
+  return {
+    total: v?.total ?? 0,
+    passed: v?.passed ?? 0,
+    failed: v?.failed ?? 0,
+    skipped: v?.skipped ?? 0,
+  }
+}
+
+function artifacts(v?: Partial<ReportArtifacts>): ReportArtifacts {
+  return {
+    html: relative(v?.html ?? "index.html"),
+    screenshots: relative(v?.screenshots ?? "screenshots"),
+    video: relative(v?.video ?? "video"),
+  }
+}
+
+function status(v?: string): ReportStatus {
+  if (v === "running" || v === "pass" || v === "fail" || v === "partial") return v
+  return "partial"
+}
+
+export namespace ReportManifest {
+  export function from(input: ReportManifestInput): ReportManifest {
+    if (!input.run_id) throw new Error("invalid manifest: missing run_id")
+    if (!input.created_at) throw new Error("invalid manifest: missing created_at")
+    return {
+      run_id: input.run_id,
+      created_at: input.created_at,
+      suite: input.suite ?? "regression",
+      started_at: input.started_at,
+      ended_at: input.ended_at,
+      status: status(input.status),
+      summary: summary(input.summary),
+      artifacts: artifacts(input.artifacts),
+    }
+  }
+
+  export async function write(file: string, input: ReportManifestInput) {
+    const data = from(input)
+    await Filesystem.writeJson(file, data)
+    return data
+  }
+
+  export async function read(file: string) {
+    const data = await Filesystem.readJson<Partial<ReportManifest>>(file)
+    if (!data.run_id) throw new Error("invalid manifest: missing run_id")
+    if (!data.created_at) throw new Error("invalid manifest: missing created_at")
+    return from({
+      ...data,
+      run_id: data.run_id,
+      created_at: data.created_at,
+    })
+  }
+}
diff --git a/packages/opencode/src/report/run.ts b/packages/opencode/src/report/run.ts
