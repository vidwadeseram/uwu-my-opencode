new file mode 100644
index 0000000..ad6561d
--- /dev/null
+++ b/packages/console/app/src/routes/workspace/[id]/reports/index.tsx
@@ -0,0 +1,114 @@
+import { createResource, For, Match, Show, Switch } from "solid-js"
+import "./index.css"
+import "./index.css"
+
+type Row = {
+  id: string
+  route: string
+  createdAt: string | null
+  status: "running" | "pass" | "fail" | "partial"
+  summary: {
+    total: number
+    passed: number
+    failed: number
+    skipped: number
+  }
+  issue: string | null
+}
+
+function day(v: string | null) {
+  if (!v) return "unknown"
+  const hit = v.match(/^(\d{4}-\d{2}-\d{2})/)
+  if (!hit) return "unknown"
+  return hit[1]
+}
+
+async function list() {
+  const res = await fetch("/reports?format=json")
+  if (!res.ok) throw new Error(`report list failed (${res.status})`)
+  const data = (await res.json()) as Row[]
+  return data
+}
+
+export default function WorkspaceReportsPage() {
+  const [rows] = createResource(list)
+
+  const grouped = () => {
+    const data = rows() ?? []
+    const map = new Map<string, Row[]>()
+    for (const row of data) {
+      const key = day(row.createdAt)
+      const list = map.get(key) ?? []
+      list.push(row)
+      map.set(key, list)
+    }
+    return [...map.entries()]
+  }
+
+  return (
+    <div data-page="workspace-reports">
+      <section data-component="reports-header">
+        <h1>Regression Reports</h1>
+        <p>Open generated HTML runs, screenshots, and videos from recent test executions.</p>
+      </section>
+
+      <Switch>
+        <Match when={rows.loading}>
+          <section data-component="reports-empty">Loading reports...</section>
+        </Match>
+
+        <Match when={rows.error}>
+          <section data-component="reports-error">
+            <h2>Unable to load reports</h2>
+            <p>{rows.error instanceof Error ? rows.error.message : "Request failed"}</p>
+            <p>
+              Verify the reports endpoint is available at <code>/reports</code>.
+            </p>
+          </section>
+        </Match>
+
+        <Match when={(rows() ?? []).length === 0}>
+          <section data-component="reports-empty">No report runs available yet.</section>
+        </Match>
+
+        <Match when={(rows() ?? []).length > 0}>
+          <section data-component="reports-groups">
+            <For each={grouped()}>
+              {([group, items], idx) => (
+                <details open={idx() === 0} data-component="reports-group">
+                  <summary>
+                    <span>{group}</span>
+                    <span>{items.length} runs</span>
+                  </summary>
+                  <ul>
+                    <For each={items}>
+                      {(item) => (
+                        <li data-status={item.status}>
+                          <div data-slot="row-head">
+                            <a href={item.route} target="_blank" rel="noreferrer" data-run-id={item.id}>
+                              <code>{item.id}</code>
+                            </a>
+                            <span data-slot="status">{item.status}</span>
+                          </div>
+                          <p>
+                            <span>Created:</span> <code>{item.createdAt ?? "unknown"}</code>
+                          </p>
+                          <p>
+                            <span>Summary:</span> {item.summary.passed}/{item.summary.total} passed • {item.summary.failed} failed • {item.summary.skipped} skipped
+                          </p>
+                          <Show when={item.issue}>
+                            <p data-slot="issue">{item.issue}</p>
+                          </Show>
+                        </li>
+                      )}
+                    </For>
+                  </ul>
+                </details>
+              )}
+            </For>
+          </section>
+        </Match>
+      </Switch>
+    </div>
+  )
+}
