+import { describe, expect, test } from "bun:test"
+import path from "path"
+import { Filesystem } from "../../src/util/filesystem"
+import { tmpdir } from "../fixture/fixture"
+import { ReportRun } from "../../src/report/run"
+
+describe("ReportRun.create", () => {
+  test("creates deterministic run folder tree with manifest", async () => {
+    await using tmp = await tmpdir()
+    const root = path.join(tmp.path, "logs")
+
+    const out = await ReportRun.create({ root })
+
+    expect(out.id).toMatch(/^\d{4}-\d{2}-\d{2}\d{2}-\d{2}-\d{2}$/)
+    expect(await Filesystem.isDir(path.join(root, out.id))).toBe(true)
+    expect(await Filesystem.isDir(path.join(root, out.id, "screenshots"))).toBe(true)
+    expect(await Filesystem.isDir(path.join(root, out.id, "video"))).toBe(true)
+    expect(await Filesystem.exists(path.join(root, out.id, "manifest.json"))).toBe(true)
+
+    const data = await Filesystem.readJson<{ run_id: string; created_at: string }>(path.join(root, out.id, "manifest.json"))
+    expect(data.run_id).toBe(out.id)
+    expect(typeof data.created_at).toBe("string")
+  })
+
+  test("rejects traversal run ids", async () => {
+    await using tmp = await tmpdir()
+    const root = path.join(tmp.path, "logs")
+
+    await expect(ReportRun.create({ root, id: "../../tmp/pwn" })).rejects.toThrow("invalid run id")
+    await expect(ReportRun.create({ root, id: "bad/name" })).rejects.toThrow("invalid run id")
+    await expect(ReportRun.create({ root, id: "bad\\name" })).rejects.toThrow("invalid run id")
+  })
+})
