+++ b/packages/opencode/src/report/run.ts
@@ -0,0 +1,74 @@
+import fs from "fs/promises"
+import path from "path"
+import { Filesystem } from "@/util/filesystem"
+import { ReportManifest } from "@/report/manifest"
+
+const RE = /^\d{4}-\d{2}-\d{2}\d{2}-\d{2}-\d{2}$/
+
+function pad(x: number) {
+  return String(x).padStart(2, "0")
+}
+
+function stamp(d: Date) {
+  const y = d.getUTCFullYear()
+  const m = pad(d.getUTCMonth() + 1)
+  const day = pad(d.getUTCDate())
+  const h = pad(d.getUTCHours())
+  const min = pad(d.getUTCMinutes())
+  const s = pad(d.getUTCSeconds())
+  return `${y}-${m}-${day}${h}-${min}-${s}`
+}
+
+function valid(id: string) {
+  if (!id) return false
+  if (id.includes("..")) return false
+  if (id.includes("/") || id.includes("\\")) return false
+  return RE.test(id)
+}
+
+function safe(root: string, id: string) {
+  const base = Filesystem.resolve(root)
+  const dir = path.join(base, id)
+  if (!Filesystem.contains(base, dir)) {
+    throw new Error(`invalid run id: ${id}`)
+  }
+  return dir
+}
+
+export namespace ReportRun {
+  export function createId(d = new Date()) {
+    return stamp(d)
+  }
+
+  export function validate(id: string) {
+    if (valid(id)) return id
+    throw new Error(`invalid run id: ${id}`)
+  }
+
+  export async function create(input: { root: string; id?: string }) {
+    const id = validate(input.id ?? createId())
+    const dir = safe(input.root, id)
+    const shots = path.join(dir, "screenshots")
+    const video = path.join(dir, "video")
+    const manifest = path.join(dir, "manifest.json")
+
+    await fs.mkdir(shots, { recursive: true })
+    await fs.mkdir(video, { recursive: true })
+
+    if (!(await Filesystem.exists(manifest))) {
+      await ReportManifest.write(manifest, {
+        run_id: id,
+        created_at: new Date().toISOString(),
+      })
+    }
+
+    return {
+      id,
+      dir,
+      manifest,
+      screenshots: shots,
+      video,
+      html: path.join(dir, "index.html"),
+    }
+  }
+}
