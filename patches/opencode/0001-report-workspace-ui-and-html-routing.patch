+import { describe, expect, test } from "bun:test"
+import { Hono } from "hono"
+import path from "path"
+import { tmpdir } from "../fixture/fixture"
+import { ReportRun } from "../../src/report/run"
+import { ReportHTML } from "../../src/report/html"
+import { ReportRoutes } from "../../src/server/routes/report"
+import { Instance } from "../../src/project/instance"
+
+describe("ReportRoutes", () => {
+  test("serves report index, json list, run html, and assets", async () => {
+    await using tmp = await tmpdir()
+    const root = path.join(tmp.path, "logs")
+    const old = await ReportRun.create({ root, id: "2026-03-2312-30-00" })
+    const run = await ReportRun.create({ root, id: "2026-03-2312-30-01" })
+
+    await Bun.write(path.join(run.dir, "screenshots", "shot.png"), "x")
+    await Bun.write(path.join(run.dir, "video", "run.webm"), "x")
+    await ReportHTML.generate({ root, id: old.id })
+    await ReportHTML.generate({ root, id: run.id })
+
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const app = new Hono().route("/reports", ReportRoutes())
+
+        const list = await app.request("http://test/reports?format=json")
+        expect(list.status).toBe(200)
+        const rows = (await list.json()) as Array<{ id: string; route: string; summary: { total: number } }>
+        expect(rows[0]?.id).toBe(run.id)
+        expect(rows[0]?.route).toBe(`/reports/${run.id}`)
+        expect(rows[1]?.id).toBe(old.id)
+
+        const index = await app.request("http://test/reports")
+        expect(index.status).toBe(200)
+        const htmlIndex = await index.text()
+        expect(htmlIndex.includes("Regression Reports")).toBe(true)
+        expect(htmlIndex.includes(`href=\"/reports/${run.id}\"`)).toBe(true)
+        expect(htmlIndex.includes("Open latest run")).toBe(true)
+        expect(htmlIndex.includes(`<a class="btn latest" href="/reports/${run.id}">Open latest run</a>`)).toBe(true)
+
+        const page = await app.request(`http://test/reports/${run.id}`)
+        expect(page.status).toBe(200)
+        const html = await page.text()
+        expect(html.includes(`Regression Run <code>${run.id}</code>`)).toBe(true)
+
+        const media = await app.request(`http://test/reports/${run.id}/video/run.webm`)
+        expect(media.status).toBe(200)
+      },
+    })
+  })
+
+  test("renders empty state when logs have no runs", async () => {
+    await using tmp = await tmpdir()
+
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const app = new Hono().route("/reports", ReportRoutes())
+        const page = await app.request("http://test/reports")
+        expect(page.status).toBe(200)
+        const html = await page.text()
+        expect(html.includes("No report runs available yet.")).toBe(true)
+      },
+    })
+  })
+
+  test("renders warning content when run artifacts are missing", async () => {
+    await using tmp = await tmpdir()
+    const root = path.join(tmp.path, "logs")
+    const run = await ReportRun.create({ root, id: "2026-03-2312-30-02" })
+
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const app = new Hono().route("/reports", ReportRoutes())
+        const page = await app.request(`http://test/reports/${run.id}`)
+        expect(page.status).toBe(200)
+        const html = await page.text()
+        expect(html.includes("No screenshots found.")).toBe(true)
+        expect(html.includes("No video found.")).toBe(true)
+      },
+    })
+  })
+
+  test("rejects traversal attacks on report file route", async () => {
+    await using tmp = await tmpdir()
+    const root = path.join(tmp.path, "logs")
+    const run = await ReportRun.create({ root, id: "2026-03-2312-30-01" })
+    await ReportHTML.generate({ root, id: run.id })
+
+    await Instance.provide({
+      directory: tmp.path,
+      fn: async () => {
+        const app = new Hono().route("/reports", ReportRoutes())
+        const bad = await app.request(`http://test/reports/${run.id}/..%2F..%2Fetc%2Fpasswd`)
+        expect(bad.status).toBe(400)
+      },
+    })
+  })
+})
