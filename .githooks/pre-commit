#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if ! printf '%s\n' "$STAGED_FILES" | grep -q '^daemon/'; then
  exit 0
fi

echo "[pre-commit] running daemon formatting and checks"

cargo fmt --manifest-path daemon/Cargo.toml --all -- --check
cargo check --manifest-path daemon/Cargo.toml

echo "[pre-commit] daemon checks passed"
